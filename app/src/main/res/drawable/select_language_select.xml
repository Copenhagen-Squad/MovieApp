<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/background_bottom_sheet_card"/>
            <corners android:radius="@dimen/radius_lg"/>
            <stroke android:color="@color/brand_secondary" android:width="1dp"/>
        </shape>
    </item>

    <item android:state_selected="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/background_bottom_sheet_card"/>
            <corners android:radius="@dimen/radius_lg"/>
            <stroke android:color="@color/background_bottom_sheet_card" android:width="1dp"/>
        </shape>
    </item>

</selector>