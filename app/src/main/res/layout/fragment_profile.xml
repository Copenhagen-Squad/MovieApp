<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="viewModel"
            type="com.karrar.movieapp.ui.profile.ProfileViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">


        <com.karrar.movieapp.ui.components.header.AppBar
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:AppBarTitle="@string/profile"
            app:showIcon="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background_screen"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            >


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/user_profile_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:background="@drawable/collection_item"
                android:onClick="@{() -> viewModel.onClickEditProfile()}"
                >
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/image_actor"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:scaleType="centerCrop"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_margin="12dp"
                    app:layout_constraintDimensionRatio="1:1"
                    app:posterImage="@{viewModel.profileDetailsUIState.avatarPath}"
                    app:shapeAppearanceOverlay="@style/Circle"
                    tools:background="@drawable/actor" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintStart_toEndOf="@id/image_actor"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="16dp"
                    >

                    <TextView
                        android:id="@+id/text_name_actor"
                        style="@style/Typography.body_lg_medium"
                        android:textColor="@color/shade_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{viewModel.profileDetailsUIState.name}"
                        tools:text="Name"
                        />

                    <TextView
                        android:id="@+id/text_username"
                        style="@style/Typography.body_sm_medium"
                        android:textColor="@color/shade_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{@string/at + viewModel.profileDetailsUIState.username}"
                        tools:text="username"
                        />

                </LinearLayout>

                <ImageView
                    android:contentDescription="@string/username"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@color/shade_tertiary"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginEnd="12dp"
                    />


            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/user_info_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/user_profile_section"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"
                >

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip"
                    android:layout_marginEnd="8dp"
                    android:onClick="@{() -> viewModel.onClickWatchHistory()}"
                    >

                    <ImageView
                        android:id="@+id/icon_history"
                        android:contentDescription="@string/history"
                        app:tint="@color/brand_primary"
                        android:src="@drawable/ic_history_duetone"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginVertical="8dp"
                        android:layout_marginStart="10dp"
                        />

                    <TextView
                        style="@style/Typography.label_md_medium"
                        android:textColor="@color/shade_primary"
                        android:text="@string/history"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/icon_history"
                        android:layout_marginStart="6dp"
                        android:paddingEnd="12dp"
                        />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip"
                    android:layout_marginEnd="8dp"
                    android:onClick="@{() -> viewModel.onClickMyCollection()}"
                    >

                    <ImageView
                        android:id="@+id/icon_my_collections"
                        android:contentDescription="@string/my_collections"
                        app:tint="@color/brand_primary"
                        android:src="@drawable/ic_video_library_duetone"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginVertical="8dp"
                        android:layout_marginStart="10dp"
                        />

                    <TextView
                        style="@style/Typography.label_md_medium"
                        android:textColor="@color/shade_primary"
                        android:text="@string/my_collections"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/icon_my_collections"
                        android:layout_marginStart="6dp"
                        android:paddingEnd="12dp"
                        />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip"
                    android:layout_marginEnd="8dp"
                    android:onClick="@{() -> viewModel.onClickRatedMovies()}"
                    >

                    <ImageView
                        android:id="@+id/icon_my_ratings"
                        android:contentDescription="@string/my_ratings"
                        app:tint="@color/brand_primary"
                        android:src="@drawable/ic_star_duetone"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginVertical="8dp"
                        android:layout_marginStart="10dp"
                        />

                    <TextView
                        style="@style/Typography.label_md_medium"
                        android:textColor="@color/shade_primary"
                        android:text="@string/my_ratings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/icon_my_ratings"
                        android:layout_marginStart="6dp"
                        android:paddingEnd="12dp"
                        />

                </androidx.constraintlayout.widget.ConstraintLayout>


            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/settings_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/user_info_section"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp"
                >

                <TextView
                    android:id="@+id/settings_title"
                    style="@style/Typography.title_sm"
                    android:textColor="@color/shade_primary"
                    android:text="@string/settings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/settings_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:background="@drawable/collection_item"
                    android:layout_marginTop="12dp"
                    >

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/dark_mode_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:contentDescription="@string/dark_mode"
                            android:id="@+id/icon_dark_mode"
                            android:src="@drawable/ic_moon_duetone"
                            app:tint="@color/brand_primary"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginVertical="18dp"
                            android:layout_marginStart="16dp"
                            />

                        <TextView
                            style="@style/Typography.body_md_medium"
                            android:textColor="@color/shade_primary"
                            android:text="@string/dark_mode"
                            android:id="@+id/dark_mode_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/icon_dark_mode"
                            android:layout_marginStart="8dp"
                            />

                        <com.karrar.movieapp.ui.components.CustomSwitch
                            android:id="@+id/dark_mode_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginEnd="16dp"
                            />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        app:dividerColor="@color/shade_quaternary"
                        android:layout_marginHorizontal="16dp"
                        />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/language_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:onClick="@{() -> viewModel.onClickChangeLanguage()}"
                        >

                        <ImageView
                            android:contentDescription="@string/language"
                            android:id="@+id/icon_language"
                            android:src="@drawable/ic_language_duetone"
                            app:tint="@color/brand_primary"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginVertical="18dp"
                            android:layout_marginStart="16dp"
                            />

                        <TextView
                            style="@style/Typography.body_md_medium"
                            android:textColor="@color/shade_primary"
                            android:text="@string/language"
                            android:id="@+id/language_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/icon_language"
                            android:layout_marginStart="8dp"
                            />

                        <ImageView
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/shade_tertiary"
                            android:contentDescription="@string/language"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginEnd="16dp"
                            />


                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        app:dividerColor="@color/shade_quaternary"
                        android:layout_marginHorizontal="16dp"
                        />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/content_preferences_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:onClick="@{() -> viewModel.onClickContentPreferences()}"
                        >

                        <ImageView
                            android:contentDescription="@string/content_preferences"
                            android:id="@+id/icon_content_preferences"
                            android:src="@drawable/ic_color_swatch_duetone"
                            app:tint="@color/brand_primary"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginVertical="18dp"
                            android:layout_marginStart="16dp"
                            />

                        <TextView
                            style="@style/Typography.body_md_medium"
                            android:textColor="@color/shade_primary"
                            android:text="@string/content_preferences"
                            android:id="@+id/content_preferences_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/icon_content_preferences"
                            android:layout_marginStart="8dp"
                            />

                        <ImageView
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/shade_tertiary"
                            android:contentDescription="@string/content_preferences"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginEnd="16dp"
                            />


                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        app:dividerColor="@color/shade_quaternary"
                        android:layout_marginHorizontal="16dp"
                        />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/logout_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:onClick="@{() -> viewModel.onClickLogout()}"
                        >

                        <ImageView
                            android:contentDescription="@string/logout"
                            android:id="@+id/icon_logout"
                            android:src="@drawable/ic_logout_duetone"
                            app:tint="@color/additional_primary_red"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginVertical="18dp"
                            android:layout_marginStart="16dp"
                            />

                        <TextView
                            style="@style/Typography.body_md_medium"
                            android:textColor="@color/additional_primary_red"
                            android:text="@string/logout"
                            android:id="@+id/logout_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/icon_logout"
                            android:layout_marginStart="8dp"
                            />

                        <ImageView
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/additional_primary_red"
                            android:contentDescription="@string/logout"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginEnd="16dp"
                            />


                    </androidx.constraintlayout.widget.ConstraintLayout>


                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/app_version"
                style="@style/Typography.body_sm_regular"
                android:textColor="@color/shade_tertiary"
                android:text="Version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/settings_section"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="24dp"
                />

            <!--loading-->
            <include
                android:id="@+id/loading"
                layout="@layout/loading2"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:isVisible="@{viewModel.profileDetailsUIState.isLoading}"
                />

            <!-- when no logged in -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/user_profile_section_placeholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:background="@drawable/collection_item"
                android:onClick="@{() -> viewModel.onClickLogin()}"
                >
                <FrameLayout
                    android:id="@+id/image_actor_placeholder"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_margin="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    android:background="@drawable/profile_image_holder"
                    >
                    <ImageView
                        android:src="@drawable/ic_profile_duetone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        app:tint="@color/shade_secondary"
                        />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintStart_toEndOf="@id/image_actor_placeholder"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="16dp"
                    >

                    <TextView
                        android:id="@+id/text_name_actor_placeholder"
                        style="@style/Typography.body_lg_medium"
                        android:textColor="@color/shade_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_or_sign_up"
                        tools:text="Name"
                        />

                    <TextView
                        android:id="@+id/text_username_placeholder"
                        style="@style/Typography.body_sm_medium"
                        android:textColor="@color/shade_secondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/to_personalize_your_experience"
                        tools:text="username"
                        />

                </LinearLayout>

                <ImageView
                    android:contentDescription="@string/username"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@color/shade_tertiary"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginEnd="12dp"
                    />


            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/user_info_section_placeholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/user_profile_section_placeholder"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"
                >

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip"
                    android:layout_marginEnd="8dp"
                    android:onClick="@{() -> viewModel.onClickWatchHistory()}"
                    >

                    <ImageView
                        android:id="@+id/icon_history_placeholder"
                        android:contentDescription="@string/history"
                        app:tint="@color/brand_primary"
                        android:src="@drawable/ic_history_duetone"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginVertical="8dp"
                        android:layout_marginStart="10dp"
                        />

                    <TextView
                        style="@style/Typography.label_md_medium"
                        android:textColor="@color/shade_primary"
                        android:text="@string/history"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/icon_history_placeholder"
                        android:layout_marginStart="6dp"
                        android:paddingEnd="12dp"
                        />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip"
                    android:layout_marginEnd="8dp"
                    android:onClick="@{() -> viewModel.onClickMyCollection()}"
                    >

                    <ImageView
                        android:id="@+id/icon_my_collections_placeholder"
                        android:contentDescription="@string/my_collections"
                        app:tint="@color/brand_primary"
                        android:src="@drawable/ic_video_library_duetone"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginVertical="8dp"
                        android:layout_marginStart="10dp"
                        />

                    <TextView
                        style="@style/Typography.label_md_medium"
                        android:textColor="@color/shade_primary"
                        android:text="@string/my_collections"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/icon_my_collections_placeholder"
                        android:layout_marginStart="6dp"
                        android:paddingEnd="12dp"
                        />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/chip"
                    android:layout_marginEnd="8dp"
                    android:onClick="@{() -> viewModel.onClickRatedMovies()}"
                    >

                    <ImageView
                        android:id="@+id/icon_my_ratings_placeholder"
                        android:contentDescription="@string/my_ratings"
                        app:tint="@color/brand_primary"
                        android:src="@drawable/ic_star_duetone"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginVertical="8dp"
                        android:layout_marginStart="10dp"
                        />

                    <TextView
                        style="@style/Typography.label_md_medium"
                        android:textColor="@color/shade_primary"
                        android:text="@string/my_ratings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/icon_my_ratings_placeholder"
                        android:layout_marginStart="6dp"
                        android:paddingEnd="12dp"
                        />

                </androidx.constraintlayout.widget.ConstraintLayout>


            </LinearLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/settings_section_placeholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/user_info_section_placeholder"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp"
                >

                <TextView
                    android:id="@+id/settings_title_placeholder"
                    style="@style/Typography.title_sm"
                    android:textColor="@color/shade_primary"
                    android:text="@string/settings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/settings_title_placeholder"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:background="@drawable/collection_item"
                    android:layout_marginTop="12dp"
                    >

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/dark_mode_section_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:contentDescription="@string/dark_mode"
                            android:id="@+id/icon_dark_mode_placeholder"
                            android:src="@drawable/ic_moon_duetone"
                            app:tint="@color/brand_primary"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginVertical="18dp"
                            android:layout_marginStart="16dp"
                            />

                        <TextView
                            style="@style/Typography.body_md_medium"
                            android:textColor="@color/shade_primary"
                            android:text="@string/dark_mode"
                            android:id="@+id/dark_mode_text_placeholder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/icon_dark_mode_placeholder"
                            android:layout_marginStart="8dp"
                            />

                        <com.karrar.movieapp.ui.components.CustomSwitch
                            android:id="@+id/dark_mode_switch_placeholder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginEnd="16dp"
                            />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        app:dividerColor="@color/shade_quaternary"
                        android:layout_marginHorizontal="16dp"
                        />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/language_section_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:onClick="@{() -> viewModel.onClickChangeLanguage()}"
                        >

                        <ImageView
                            android:contentDescription="@string/language"
                            android:id="@+id/icon_language_placeholder"
                            android:src="@drawable/ic_language_duetone"
                            app:tint="@color/brand_primary"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginVertical="18dp"
                            android:layout_marginStart="16dp"
                            />

                        <TextView
                            style="@style/Typography.body_md_medium"
                            android:textColor="@color/shade_primary"
                            android:text="@string/language"
                            android:id="@+id/language_text_placeholder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/icon_language_placeholder"
                            android:layout_marginStart="8dp"
                            />

                        <ImageView
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/shade_tertiary"
                            android:contentDescription="@string/language"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginEnd="16dp"
                            />


                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        app:dividerColor="@color/shade_quaternary"
                        android:layout_marginHorizontal="16dp"
                        />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/content_preferences_section_placeholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:onClick="@{() -> viewModel.onClickContentPreferences()}"
                        >

                        <ImageView
                            android:contentDescription="@string/content_preferences"
                            android:id="@+id/icon_content_preferences_placeholder"
                            android:src="@drawable/ic_color_swatch_duetone"
                            app:tint="@color/brand_primary"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_marginVertical="18dp"
                            android:layout_marginStart="16dp"
                            />

                        <TextView
                            style="@style/Typography.body_md_medium"
                            android:textColor="@color/shade_primary"
                            android:text="@string/content_preferences"
                            android:id="@+id/content_preferences_text_placeholder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/icon_content_preferences_placeholder"
                            android:layout_marginStart="8dp"
                            />

                        <ImageView
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/shade_tertiary"
                            android:contentDescription="@string/content_preferences"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:layout_marginEnd="16dp"
                            />


                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/app_version_logout"
                style="@style/Typography.body_sm_regular"
                android:textColor="@color/shade_tertiary"
                android:text="Version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/settings_section_placeholder"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="24dp"
                />

            <!-- error -->
            <include
                android:id="@+id/error"
                layout="@layout/error2"
                app:isError="@{viewModel.profileDetailsUIState.error}"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:viewModel="@{viewModel}" />

            <androidx.constraintlayout.widget.Group
                android:id="@+id/group_when_success"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:constraint_referenced_ids="
            settings_section,
            user_info_section,
            user_profile_section"
                app:showProfileWhenSuccess="@{viewModel.profileDetailsUIState.username}"
                tools:visibility="visible" />


            <androidx.constraintlayout.widget.Group
                android:id="@+id/group_when_no_logged_in"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:constraint_referenced_ids="
            user_profile_section_placeholder,
            user_info_section_placeholder,
            settings_section_placeholder,
            app_version_logout"
                app:showWhenNoLoggedIn="@{viewModel.profileDetailsUIState.isLoggedIn}" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</layout>