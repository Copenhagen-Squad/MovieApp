<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="item"
            type="com.karrar.movieapp.ui.home.homeUiState.FeaturedCollectionUiState" />
    </data>
        <androidx.constraintlayout.widget.ConstraintLayout
            xmlns:tool="http://schemas.android.com/tools"
            android:layout_width="280dp"
            android:layout_height="92dp"
            android:layout_marginEnd="@dimen/spacing_medium"
            android:layout_marginBottom="@dimen/spacing_medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <androidx.cardview.widget.CardView
                android:layout_width="280dp"
                android:layout_height="80dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_collection"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    app:shapeAppearanceOverlay="@style/roundedImageViewRoundedSmall"
                    android:src="@drawable/_collection_item_placeholder"
                    app:imageRes="@{item.imageResId}"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="32.dp"
                    android:layout_gravity="bottom"
                    android:background="@color/overlay_primary" />

                <TextView
                    android:id="@+id/tv_collection_item"
                    style="@style/Typography.body_sm_medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:layout_gravity="center|bottom"
                    android:layout_marginBottom="8dp"
                    android:textColor="@color/shade_primary"
                    tool:text="Text"
                    android:text="@{item.title}"/>
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="264dp"
                android:layout_height="6dp"
                android:background="@drawable/collection_item_mid"
                app:layout_constraintBottom_toTopOf="@+id/view"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <View
                android:id="@+id/view"
                android:layout_width="248dp"
                android:layout_height="6dp"
                android:background="@drawable/collection_item_bottom"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
</layout>