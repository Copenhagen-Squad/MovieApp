<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/collection_image"
        android:layout_width="280dp"
        android:layout_height="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:src="@drawable/image"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/CardCorners.Small"/>

    <TextView
        android:id="@+id/collection_title"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="@id/collection_image"
        tools:text="Text"
        style="@style/Typography.body_md_medium"
        android:background="@drawable/bottom_rounded_corners"
        android:backgroundTint="@color/shade_primary"/>

    <View
        android:id="@+id/view1"
        android:layout_width="0dp"
        android:layout_height="6dp"
        app:layout_constraintTop_toBottomOf="@id/collection_title"
        app:layout_constraintStart_toStartOf="@id/collection_image"
        app:layout_constraintEnd_toEndOf="@id/collection_image"
        android:background="@drawable/bottom_rounded_corners"
        android:layout_marginStart="@dimen/spacing_small"
        android:layout_marginEnd="@dimen/spacing_small"
        android:backgroundTint="@color/brand_tertiary"/>

    <View
        android:id="@+id/view2"
        android:layout_width="0dp"
        android:layout_height="6dp"
        app:layout_constraintTop_toBottomOf="@id/view1"
        app:layout_constraintStart_toStartOf="@id/collection_image"
        app:layout_constraintEnd_toEndOf="@id/collection_image"
        android:layout_marginStart="@dimen/spacing_medium"
        android:layout_marginEnd="@dimen/spacing_medium"
        android:background="@drawable/bottom_rounded_corners"
        android:backgroundTint="@color/shade_quinary"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:tool="http://schemas.android.com/tools"
        android:layout_width="280dp"
        android:layout_height="92dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:layout_width="280dp"
            android:layout_height="80dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_collection"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                app:shapeAppearanceOverlay="@style/roundedImageViewRoundedSmall"
                android:src="@drawable/_collection_item_placeholder" />

            <View
                android:layout_width="match_parent"
                android:layout_height="32.dp"
                android:layout_gravity="bottom"
                android:background="@color/overlay_primary" />

            <TextView
                android:id="@+id/tv_collection_item"
                style="@style/Typography.body_sm_medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:layout_gravity="center|bottom"
                android:layout_marginBottom="8.dp"
                android:textColor="@color/shade_primary"
                tool:text="Text" />
        </FrameLayout>

        <View
            android:layout_width="264dp"
            android:layout_height="6dp"
            android:background="@drawable/collection_item_mid"
            app:layout_constraintBottom_toTopOf="@+id/view"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <View
            android:id="@+id/view"
            android:layout_width="248dp"
            android:layout_height="6dp"
            android:background="@drawable/collection_item_bottom"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>