<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.karrar.movieapp.ui.movieDetails.MovieDetailsViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Bottom Sheet Handle -->
        <View
            android:layout_width="48dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bottom_line" />

        <!-- Header with Title -->
        <TextView
            android:id="@+id/rate_the_movie"
            style="@style/SemiBold.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="24dp"
            android:text="@string/rate_the_movie"
            android:textColor="@color/shade_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:isVisible="@{viewModel.uiState.login}" />

        <!-- Emoji Row -->
        <LinearLayout
            android:id="@+id/emoji_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical">

            <!-- Very Bad - Rating 1 -->
            <ImageView
                android:id="@+id/first_emoji"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:alpha="@{viewModel.uiState.ratingValue >= 1f ? 1.0f : 0.4f}"
                android:onClick="@{() -> viewModel.onChangeRating(1f)}"
                android:src="@drawable/colored_frowning_face"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleX="@{viewModel.uiState.ratingValue == 1f ? 1.2f : 1.0f}"
                android:scaleY="@{viewModel.uiState.ratingValue == 1f ? 1.2f : 1.0f}" />

            <!-- Bad - Rating 2 -->
            <ImageView
                android:id="@+id/second_emoji"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:alpha="@{viewModel.uiState.ratingValue >= 2f ? 1.0f : 0.4f}"
                android:onClick="@{() -> viewModel.onChangeRating(2f)}"
                android:src="@drawable/colored_confused_face"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleX="@{viewModel.uiState.ratingValue == 2f ? 1.2f : 1.0f}"
                android:scaleY="@{viewModel.uiState.ratingValue == 2f ? 1.2f : 1.0f}" />

            <!-- Neutral - Rating 3 -->
            <ImageView
                android:id="@+id/third_emoji"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:alpha="@{viewModel.uiState.ratingValue >= 3f ? 1.0f : 0.4f}"
                android:onClick="@{() -> viewModel.onChangeRating(3f)}"
                android:src="@drawable/colored_neutral_face"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleX="@{viewModel.uiState.ratingValue == 3f ? 1.2f : 1.0f}"
                android:scaleY="@{viewModel.uiState.ratingValue == 3f ? 1.2f : 1.0f}" />

            <!-- Good - Rating 4 -->
            <ImageView
                android:id="@+id/fourth_emoji"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:alpha="@{viewModel.uiState.ratingValue >= 4f ? 1.0f : 0.4f}"
                android:onClick="@{() -> viewModel.onChangeRating(4f)}"
                android:src="@drawable/colored_smiling_face_with_smiling_eyes"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleX="@{viewModel.uiState.ratingValue == 4f ? 1.2f : 1.0f}"
                android:scaleY="@{viewModel.uiState.ratingValue == 4f ? 1.2f : 1.0f}" />

            <!-- Excellent - Rating 5 -->
            <ImageView
                android:id="@+id/fifth_emoji"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:alpha="@{viewModel.uiState.ratingValue >= 5f ? 1.0f : 0.4f}"
                android:onClick="@{() -> viewModel.onChangeRating(5f)}"
                android:src="@drawable/colored_star_struck"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/rating_excellent"
                android:scaleX="@{viewModel.uiState.ratingValue == 5f ? 1.2f : 1.0f}"
                android:scaleY="@{viewModel.uiState.ratingValue == 5f ? 1.2f : 1.0f}" />

        </LinearLayout>

        <!-- Stars Row -->
        <LinearLayout
            android:id="@+id/stars_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp">

            <ImageView
                android:id="@+id/first_star"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:onClick="@{() -> viewModel.onChangeRating(1f)}"
                android:src="@drawable/star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="1 Stars"
                app:tint="@color/shade_tertiary" />

            <ImageView
                android:id="@+id/second_star"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:onClick="@{() -> viewModel.onChangeRating(2f)}"
                android:src="@drawable/star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="2 Stars"
                app:tint="@color/shade_tertiary" />

            <ImageView
                android:id="@+id/third_star"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:onClick="@{() -> viewModel.onChangeRating(3f)}"
                android:src="@drawable/star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="3 Stars"
                app:tint="@color/shade_tertiary" />

            <ImageView
                android:id="@+id/fourth_star"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:onClick="@{() -> viewModel.onChangeRating(4f)}"
                android:src="@drawable/star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="4 Stars"
                app:tint="@color/shade_tertiary" />

            <ImageView
                android:id="@+id/fifth_star"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:onClick="@{() -> viewModel.onChangeRating(5f)}"
                android:src="@drawable/star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="5 Stars"
                app:tint="@color/shade_tertiary" />
        </LinearLayout>

        <!-- Add Rating Button -->
        <Button
            android:id="@+id/add_rating_button"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginStart="16dp"
            android:background="@{viewModel.uiState.ratingValue > 0f ? @drawable/button_primary_background : @drawable/button_secondary_background}"
            android:text="@string/add_rating"
            android:textColor="@{viewModel.uiState.ratingValue > 0f ? @color/button_onPrimary : @color/button_onSecondary}"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:enabled="@{viewModel.uiState.ratingValue > 0f}"
            style="@style/Typography.title_xl"
            android:gravity="center" />

    </LinearLayout>

</layout>