<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="com.karrar.movieapp.ui.movieDetails.MovieDetailsViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="336dp"
        android:layout_height="221dp"
        android:background="@drawable/rounded_corners"
        android:padding="16dp">

        <!-- Header with Title and Close Button -->
        <LinearLayout
            android:id="@+id/header_layout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/rate_the_movie"
                style="@style/SemiBold.Medium"
                android:layout_width="0dp"
                android:paddingStart="@dimen/radius_lg"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/rate_the_movie"
                android:textColor="@color/shade_primary"
                app:isVisible="@{viewModel.uiState.login}" />

            <ImageView
                android:id="@+id/close_button"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_x"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close" />
        </LinearLayout>

        <!-- Emoji Row -->
        <LinearLayout
            android:id="@+id/emoji_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/header_layout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Very Bad - Rating 1 -->
            <ImageView
                android:id="@+id/first_emoji"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="12dp"
                android:alpha="0.4"
                android:onClick="@{() -> viewModel.onChangeRating(1f)}"
                android:src="@drawable/colored_frowning_face"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <!-- Bad - Rating 2 -->
            <ImageView
                android:id="@+id/second_emoji"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="12dp"
                android:alpha="0.4"
                android:onClick="@{() -> viewModel.onChangeRating(2f)}"
                android:src="@drawable/colored_confused_face"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <!-- Neutral - Rating 3 (Selected) -->
            <ImageView
                android:id="@+id/third_emoji"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:alpha="1.0"
                android:padding="2dp"
                android:onClick="@{() -> viewModel.onChangeRating(3f)}"
                android:src="@drawable/colored_neutral_face" />

            <!-- Good - Rating 4 (Selected) -->
            <ImageView
                android:id="@+id/fourth_emoji"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:alpha="1.0"
                android:padding="2dp"
                android:onClick="@{() -> viewModel.onChangeRating(4f)}"
                android:src="@drawable/colored_smiling_face_with_smiling_eyes" />

            <!-- Excellent - Rating 5 -->
            <ImageView
                android:id="@+id/fifth_emoji"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:alpha="0.4"
                android:onClick="@{() -> viewModel.onChangeRating(5f)}"
                android:src="@drawable/colored_star_struck"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/rating_excellent" />

        </LinearLayout>

        <!-- Stars Row -->
        <LinearLayout
            android:id="@+id/stars_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/emoji_layout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:starsDrawableByRating="@{viewModel.uiState.ratingValue}">

            <ImageView
                android:id="@+id/first_star"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:onClick="@{() -> viewModel.onChangeRating(2f)}"
                android:src="@drawable/star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="1 Stars"
                app:tint="@color/shade_tertiary" />

            <ImageView
                android:id="@+id/second_star"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:onClick="@{() -> viewModel.onChangeRating(2f)}"
                android:src="@drawable/star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="2 Stars"
                app:tint="@color/shade_tertiary" />

            <ImageView
                android:id="@+id/third_star"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:onClick="@{() -> viewModel.onChangeRating(3f)}"
                android:src="@drawable/star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="3 Stars"
                app:tint="@color/shade_tertiary" />

            <ImageView
                android:id="@+id/fourth_star"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:onClick="@{() -> viewModel.onChangeRating(4f)}"
                android:src="@drawable/star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="4 Stars"
                app:tint="@color/shade_tertiary" />

            <ImageView
                android:id="@+id/fifth_star"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:onClick="@{() -> viewModel.onChangeRating(5f)}"
                android:src="@drawable/star_outline"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="5 Stars"
                app:tint="@color/shade_tertiary" />
        </LinearLayout>

        <!-- Add Rating Button -->
        <Button
            android:id="@+id/add_rating_button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@color/button_onDisabled"
            android:text="@string/add_rating"
            android:textColor="@color/button_onDisabled"
            android:textSize="16sp"
            style="@style/Typography.body_md_medium"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/stars_layout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>