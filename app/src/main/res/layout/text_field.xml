<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Container -->
    <LinearLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/text_field"
        android:layout_marginHorizontal="16dp"
        >

        <ImageView
            android:id="@+id/start_icon"
            android:contentDescription="@string/create_new_collection"
            android:src="@drawable/ic_folder"
            app:tint="@color/shade_tertiary"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:layout_marginVertical="14dp"
            android:layout_marginStart="12dp"
            />

        <EditText
            style="@style/Typography.body_md_regular"
            android:id="@+id/editText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/e_g_my_watchlist"
            android:background="@null"
            android:textColor="@color/shade_primary"
            android:textColorHint="@color/shade_tertiary"
            android:inputType="text"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:maxLines="1"
            />
    </LinearLayout>

</merge>
