<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_small_loading"
        android:layout_width="72dp"
        android:layout_height="48dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/button_primary"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:layout_marginHorizontal="32dp"
            android:src="@drawable/ic_progress" />

    </androidx.cardview.widget.CardView>

    <!-- Small Primary Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_small_primary"
        android:layout_width="93dp"
        android:layout_height="48dp"
        android:layout_marginStart="24dp"
        app:cardBackgroundColor="@color/button_primary"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toEndOf="@id/card_small_loading"
        app:layout_constraintTop_toTopOf="@id/card_small_loading">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingHorizontal="24dp"
            android:text="Button"
            android:textSize="14sp"
            android:fontFamily="@font/manrope_medium" />


    </androidx.cardview.widget.CardView>

    <!-- Small Disabled Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_small_disabled"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:alpha="0.5"
        app:cardBackgroundColor="@color/button_disabled"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toEndOf="@id/card_small_primary"
        app:layout_constraintTop_toTopOf="@id/card_small_loading">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingHorizontal="24dp"
            android:text="Button"
            android:textColor="@color/button_onDisabled"
            android:textSize="14sp"
            android:textStyle="bold" />

    </androidx.cardview.widget.CardView>

    <!-- Row 2: Medium buttons -->

    <!-- Medium Loading Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_medium_loading"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/button_primary"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="@id/card_small_loading"
        app:layout_constraintTop_toBottomOf="@id/card_small_loading">

        <ProgressBar
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:layout_marginHorizontal="36dp"
            android:indeterminateTint="@color/cardview_light_background"
            style="?android:attr/progressBarStyleSmall" />

    </androidx.cardview.widget.CardView>

    <!-- Medium Primary Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_medium_primary"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        app:cardBackgroundColor="@color/button_primary"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toEndOf="@id/card_medium_loading"
        app:layout_constraintTop_toTopOf="@id/card_medium_loading">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingHorizontal="28dp"
            android:text="Button"
            android:textColor="@color/button_onPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

    </androidx.cardview.widget.CardView>

    <!-- Medium Disabled Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_medium_disabled"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:alpha="0.5"
        app:cardBackgroundColor="@color/button_disabled"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toEndOf="@id/card_medium_primary"
        app:layout_constraintTop_toTopOf="@id/card_medium_loading">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingHorizontal="28dp"
            android:text="Button"
            android:textColor="@color/button_onDisabled"
            android:textSize="16sp"
            android:textStyle="bold" />

    </androidx.cardview.widget.CardView>

    <!-- Row 3: Large buttons -->

    <!-- Large Loading Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_large_loading"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/button_primary"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="@id/card_medium_loading"
        app:layout_constraintTop_toBottomOf="@id/card_medium_loading">

        <ProgressBar
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:layout_marginHorizontal="40dp"
            style="?android:attr/progressBarStyleSmall" />

    </androidx.cardview.widget.CardView>

    <!-- Large Primary Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_large_primary"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        app:cardBackgroundColor="@color/button_primary"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toEndOf="@id/card_large_loading"
        app:layout_constraintTop_toTopOf="@id/card_large_loading">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingHorizontal="32dp"
            android:text="Button"
            android:textColor="@color/button_onDisabled"
            android:textSize="18sp"
            android:textStyle="bold" />

    </androidx.cardview.widget.CardView>

    <!-- Large Disabled Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_large_disabled"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:alpha="0.5"
        app:cardBackgroundColor="@color/button_disabled"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toEndOf="@id/card_large_primary"
        app:layout_constraintTop_toTopOf="@id/card_large_loading">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingHorizontal="32dp"
            android:text="Button"
            android:textColor="@color/button_onDisabled"
            android:textSize="18sp"
            android:textStyle="bold" />

    </androidx.cardview.widget.CardView>

    <!-- Floating Action Buttons Section -->

    <!-- Small Floating Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/fab_small"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/button_primary"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="@id/card_large_loading"
        app:layout_constraintTop_toBottomOf="@id/card_large_loading">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_add"
            android:tint="@color/button_onDisabled"
            tools:ignore="UseAppTint" />

    </androidx.cardview.widget.CardView>

    <!-- Progress Indicator (24x24) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/progress_indicator"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        app:cardBackgroundColor="@color/button_primary"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toEndOf="@id/fab_small"
        app:layout_constraintTop_toTopOf="@id/fab_small">

        <ProgressBar
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/button_onDisabled"
            style="?android:attr/progressBarStyleSmall" />

    </androidx.cardview.widget.CardView>

    <!-- Extended Floating Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/fab_extended"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/button_primary"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="@id/fab_small"
        app:layout_constraintTop_toBottomOf="@id/fab_small">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Get Started"
                android:textColor="@color/button_onDisabled"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_magic_stick"
                android:tint="@color/button_onDisabled"
                tools:ignore="UseAppTint" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Bottom section with outlined button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/outlined_button"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/fab_extended"
        app:layout_constraintTop_toBottomOf="@id/fab_extended">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/back_icon_shape">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:paddingHorizontal="24dp"
                android:text="Button"
                android:textColor="@color/button_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

        </FrameLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>