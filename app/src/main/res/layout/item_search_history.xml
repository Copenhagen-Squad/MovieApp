<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="item"
            type="com.karrar.movieapp.ui.search.mediaSearchUIState.SearchHistoryUIState" />

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.search.adapters.SearchHistoryInteractionListener" />

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"

        >
        <TextView
            android:id="@+id/text_search_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14.5dp"
            android:layout_marginBottom="14.5dp"
            tools:text="Star Wars"
            android:text="@{item.name}"
            style="@style/Typography.body_md_medium"
            android:textColor="@color/shade_secondary"
            android:drawablePadding="6dp"
            app:drawableStartCompat="@drawable/ic_history"
            app:drawableTint="@color/shade_tertiary"
            app:drawableEndCompat="@drawable/ic_arrow_up_left"
            android:onClick="@{() -> listener.onClickSearchHistory(item.name)}"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/shade_quaternary"
            />

    </LinearLayout>


</layout>