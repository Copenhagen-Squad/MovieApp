<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="mood"
            type="com.karrar.movieapp.ui.models.MoodUi" />

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.adapters.MoodInteractionListener"/>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/radius_lg">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_emotional"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardElevation="10dp"
            android:background="@drawable/mood_btn"
            android:onClick="@{ () -> listener.onClickMode(mood.id)}"
            android:selected="@{mood.selected}"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="@dimen/spacing_extra_small"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/mood_icon_btn"
                    android:layout_width="@dimen/chip_height"
                    android:layout_height="@dimen/chip_height"
                    app:cardElevation="0dp"
                    android:layout_marginEnd="@dimen/spacing_extra_small"
                    android:backgroundTint="@color/brand_tertiary"
                    app:cardCornerRadius="@dimen/radius_md">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/icon"
                        tools:src="@drawable/ic_headphone_duetone"
                        android:src="@{mood.icon}"
                        app:tint="@color/brand_primary"
                        android:layout_gravity="center" />
                </androidx.cardview.widget.CardView>


                <TextView
                    android:id="@+id/mood_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Emotional"
                    android:text="@{mood.name}"
                    style="@style/Typography.body_md_medium"
                    android:textColor="@{mood.selected ? @color/brand_primary: @color/shade_primary }" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>