<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="listener"
            type="com.karrar.movieapp.ui.adapters.MovieInteractionListener" />

        <variable
            name="item"
            type="com.karrar.movieapp.ui.home.homeUiState.PopularUiState" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:onClick="@{()->listener.onClickMovie(item.movieID)}"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/spacing_small">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/image_movie"
            android:layout_width="@dimen/media_card_popular_movie"
            android:layout_height="0dp"
            android:layout_marginHorizontal="@dimen/spacing_small"
            android:scaleType="centerCrop"
            app:layout_constraintDimensionRatio="1.75:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:posterImage="@{item.imageUrl}"
            app:shapeAppearanceOverlay="@style/CardCorners.Medium" />

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/gradient"
            app:layout_constraintBottom_toBottomOf="@+id/image_movie"
            app:layout_constraintEnd_toEndOf="@id/image_movie"
            app:layout_constraintStart_toStartOf="@id/image_movie"
            app:layout_constraintTop_toTopOf="@id/image_movie"
            app:shapeAppearanceOverlay="@style/CardCorners.Medium" />


        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            android:layout_marginTop="@dimen/radius_lg"
            android:layout_marginEnd="@dimen/radius_lg"
            app:cardCornerRadius="@dimen/radius_full"
            app:cardBackgroundColor="@color/background_card"
            android:layout_gravity="center_horizontal"
            app:layout_constraintTop_toTopOf="@id/image_movie"
            app:layout_constraintEnd_toEndOf="@id/image_movie">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/imageView4"
                    android:layout_width="@dimen/radius_xl"
                    android:layout_height="@dimen/radius_xl"
                    android:contentDescription="@string/icon"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginEnd="@dimen/radius_xs"
                    android:layout_marginTop="@dimen/radius_xs"
                    android:layout_marginBottom="@dimen/radius_xs"
                    app:srcCompat="@drawable/ic_star_duetone"
                    app:tint="@color/additional_primary_yellow" />

                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_marginEnd="@dimen/radius_xs"
                    android:layout_marginStart="@dimen/radius_s"
                    android:text="@{String.format(`%.1f`, item.movieRate)}"
                    style="@style/Typography.label_md_medium"
                    android:textColor="@color/shade_primary"
                    tools:text="7.5"
                    app:layout_constraintBottom_toBottomOf="@+id/imageView4"
                    app:layout_constraintEnd_toStartOf="@+id/imageView4"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/imageView4" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/text_movie_title"
            style="@style/Typography.body_md_medium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/radius_3xl"
            android:layout_marginEnd="@dimen/radius_3xl"
            android:paddingStart="@dimen/radius_lg"
            android:paddingEnd="@dimen/radius_lg"
            android:ellipsize="end"
            android:lines="1"
            android:text="@{item.title}"
            tools:text="Fountain of Youth"
            android:gravity="center"
            android:textColor="@color/shade_primary"
            app:layout_constraintTop_toBottomOf="@id/image_movie"
            app:layout_constraintStart_toStartOf="@id/image_movie"
            app:layout_constraintEnd_toEndOf="@id/image_movie"/>

        <TextView
            android:id="@+id/text_category"
            style="@style/Typography.body_sm_regular"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/spacing_too_small"
            android:layout_marginStart="@dimen/radius_3xl"
            android:layout_marginEnd="@dimen/radius_3xl"
            android:paddingStart="@dimen/radius_lg"
            android:paddingEnd="@dimen/radius_lg"
            android:gravity="center"
            android:lines="1"
            android:textColor="@color/shade_secondary"
            android:text="@{item.formattedGenre}"
            tools:text="Adventure, Fantasy, Mystery"
            app:layout_constraintTop_toBottomOf="@id/text_movie_title"
            app:layout_constraintStart_toStartOf="@+id/image_movie"
            app:layout_constraintEnd_toEndOf="@id/image_movie"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
