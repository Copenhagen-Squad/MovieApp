<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/option_hide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/select_language_select"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            >

            <FrameLayout
                android:id="@+id/icon_container_hide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:background="@drawable/icon_container"
                android:layout_marginVertical="24dp"
                android:layout_marginStart="12dp"
                >
                <ImageView
                    android:id="@+id/icon_hide"
                    android:src="@drawable/ic_eye_slash_duetone"
                    app:tint="@color/shade_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    />
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/icon_container_hide"
                android:layout_marginStart="12dp"
                android:paddingEnd="12dp"
                >

                <TextView
                    android:id="@+id/title_content_hide"
                    style="@style/Typography.body_md_medium"
                    android:textColor="@color/shade_primary"
                    android:text="@string/hide_explicit_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    />

                <TextView
                    android:id="@+id/description_content_hide"
                    style="@style/Typography.body_md_medium"
                    android:textColor="@color/shade_secondary"
                    android:text="@string/hides_revealing_or_inappropriate_posters_e_g_nudity_strong_sexual_content"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/option_filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/select_language_select"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"
            >

            <FrameLayout
                android:id="@+id/icon_container_filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:background="@drawable/icon_container"
                android:layout_marginVertical="24dp"
                android:layout_marginStart="12dp"
                >
                <ImageView
                    android:id="@+id/icon_filter"
                    android:src="@drawable/ic_slash_duetone"
                    app:tint="@color/shade_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    />
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/icon_container_filter"
                android:layout_marginStart="12dp"
                android:paddingEnd="12dp"
                >

                <TextView
                    android:id="@+id/title_content_filter"
                    style="@style/Typography.body_md_medium"
                    android:textColor="@color/shade_primary"
                    android:text="@string/strict_filtering"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    />

                <TextView
                    android:id="@+id/description_content_filter"
                    style="@style/Typography.body_md_medium"
                    android:textColor="@color/shade_secondary"
                    android:text="@string/hides_all_content_that_includes_immodest_clothing_or_behavior"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/option_show"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/select_language_select"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"
            >

            <FrameLayout
                android:id="@+id/icon_container_show"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:background="@drawable/icon_container"
                android:layout_marginVertical="24dp"
                android:layout_marginStart="12dp"
                >
                <ImageView
                    android:id="@+id/icon_show"
                    android:src="@drawable/ic_eye_duetone"
                    app:tint="@color/shade_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    />
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/icon_container_show"
                android:layout_marginStart="12dp"
                android:paddingEnd="12dp"
                >

                <TextView
                    android:id="@+id/title_content_show"
                    style="@style/Typography.body_md_medium"
                    android:textColor="@color/shade_primary"
                    android:text="@string/show_all_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    />

                <TextView
                    android:id="@+id/description_content_show"
                    style="@style/Typography.body_md_medium"
                    android:textColor="@color/shade_secondary"
                    android:text="@string/no_filtering_all_images_and_posters_will_be_displayed"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>