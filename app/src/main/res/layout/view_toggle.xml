<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">


    <data>

        <variable
            name="state"
            type="com.karrar.movieapp.ui.explore.exploreUIState.ViewToggle" />

        <variable
            name="onGridClick"
            type="android.view.View.OnClickListener" />

        <variable
            name="onListClick"
            type="android.view.View.OnClickListener" />
    </data>

    <LinearLayout
        android:layout_width="80dp"
        android:orientation="horizontal"
        android:background="@drawable/view_toggle_background"
        android:layout_height="40dp">

        <FrameLayout
            android:layout_gravity="start"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@{state == com.karrar.movieapp.ui.explore.exploreUIState.ViewToggle.GRID ? @drawable/selected_view_toggle_background : @drawable/unselected_view_toggle_background}"
            android:onClick="@{onGridClick}">


            <ImageView
                android:layout_gravity="center"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@{state == com.karrar.movieapp.ui.explore.exploreUIState.ViewToggle.GRID ? @drawable/ic_grid_duetone : @drawable/ic_grid}"
                android:tint="@{state == com.karrar.movieapp.ui.explore.exploreUIState.ViewToggle.GRID ? @color/brand_primary : @color/shade_secondary}" />
        </FrameLayout>

        <FrameLayout
            android:layout_gravity="end"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@{state == com.karrar.movieapp.ui.explore.exploreUIState.ViewToggle.LIST ? @drawable/selected_view_toggle_background : @drawable/unselected_view_toggle_background}"
            android:onClick="@{onListClick}">


            <ImageView
                android:layout_gravity="center"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@{state == com.karrar.movieapp.ui.explore.exploreUIState.ViewToggle.LIST ? @drawable/ic_grid_list_duetone : @drawable/ic_grid_list}"
                android:tint="@{state == com.karrar.movieapp.ui.explore.exploreUIState.ViewToggle.LIST ? @color/brand_primary : @color/shade_secondary}" />
        </FrameLayout>

    </LinearLayout>
</layout>