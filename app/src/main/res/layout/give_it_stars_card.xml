<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="viewModel"
            type="com.karrar.movieapp.ui.movieDetails.MovieDetailsViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="715dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp">

        <!-- Main Rating Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/rating_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardBackgroundColor="@color/background_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="328dp"
                android:layout_height="114dp"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Header Section -->
                <TextView
                    android:id="@+id/tv_header"
                    style="@style/Typography.title_sm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="@string/did_you_watch_it"
                    android:textColor="@color/shade_primary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:onClick="@{() -> viewModel.showRatingBottomSheet()}"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <!-- Star Icon Container -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="16dp"
                        app:cardBackgroundColor="@color/shade_quinary"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:id="@+id/iv_star_icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_star"
                            android:tint="@color/brand_primary"
                            tools:ignore="UseAppTint" />

                    </androidx.cardview.widget.CardView>

                    <!-- Text Content -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_title"
                            style="@style/Typography.title_sm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/give_it_stars"
                            android:textColor="@android:color/black" />

                        <TextView
                            android:id="@+id/tv_subtitle"
                            style="@style/Typography.body_sm_medium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/let_the_world_know_how_you_felt"
                            android:textColor="@color/shade_secondary" />

                    </LinearLayout>

                    <!-- Arrow Icon -->
                    <ImageView
                        android:id="@+id/iv_arrow"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="#A5A5A5"
                        tools:ignore="UseAppTint" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>