<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Typography style -->
    <style name="Typography" />

    <!-- Display / xl -->
    <style name="Typography.display_xl">
        <item name="fontFamily">@font/manrope_bold</item>
        <item name="android:textSize">40sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!--Title-->
    <style name="Typography.title_xl">
        <item name="fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="Typography.title_lg">
        <item name="fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="Typography.title_md">
        <item name="fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="Typography.title_sm">
        <item name="fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Body / Lg -->
    <style name="Typography.body_lg_regular">
        <item name="fontFamily">@font/manrope_regular</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Typography.body_lg_medium">
        <item name="fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Typography.body_lg_semi_bold">
        <item name="fontFamily">@font/manrope_semi_bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Body / Md -->
    <style name="Typography.body_md_regular">
        <item name="fontFamily">@font/manrope_regular</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Typography.body_md_medium">
        <item name="fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Typography.body_md_semi_bold">
        <item name="fontFamily">@font/manrope_semi_bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Body / Sm -->
    <style name="Typography.body_sm_regular">
        <item name="fontFamily">@font/manrope_regular</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Typography.body_sm_medium">
        <item name="fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Typography.body_sm_semi_bold">
        <item name="fontFamily">@font/manrope_semi_bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Label / Md -->
    <style name="Typography.label_md_regular">
        <item name="fontFamily">@font/manrope_regular</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Typography.label_md_medium">
        <item name="fontFamily">@font/manrope_medium</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Typography.label_md_semi_bold">
        <item name="fontFamily">@font/manrope_semi_bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- radius / Lg -->
    <style name="CustomFabStyle" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="shapeAppearanceOverlay">@style/CustomFabCorners</item>
    </style>

    <style name="CustomFabCorners">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="RoundedCorners" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>


    <style name="roundedImageViewRoundedSmall">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.CustomRounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">12dp</item>
        <item name="cornerSizeTopRight">12dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerSizeBottomLeft">12dp</item>
    </style>

    <style name="CardCorners.SharpBottomRight">
        <item name="cornerSizeBottomRight">0dp</item>
        <item name="cornerSizeBottomLeft">@dimen/radius_lg</item>
        <item name="cornerSizeTopLeft">@dimen/radius_lg</item>
        <item name="cornerSizeTopRight">@dimen/radius_lg</item>
    </style>

</resources>