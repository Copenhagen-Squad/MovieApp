<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Navigation Item Styles -->
    <style name="NavItemContainer">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>

    <style name="NavIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
    </style>

    <!-- Using your typography system for labels -->
    <style name="NavLabel" parent="Typography.label_md_medium">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">4dp</item>
    </style>

    <!-- Selected State -->
    <style name="NavIcon.Selected" parent="NavIcon">
        <item name="android:tint">@color/brand_primary</item>
    </style>

    <style name="NavLabel.Selected" parent="NavLabel">
        <item name="android:textColor">@color/brand_primary</item>
    </style>

    <!-- Unselected State -->
    <style name="NavIcon.Unselected" parent="NavIcon">
        <item name="android:tint">@color/shade_tertiary</item>
    </style>

    <style name="NavLabel.Unselected" parent="NavLabel">
        <item name="android:textColor">@color/shade_tertiary</item>
    </style>

    <!-- Dark theme variant for your screenshots -->
    <style name="NavIcon.Selected.Dark" parent="NavIcon">
        <item name="android:tint">#8C9EFF</item>
    </style>

    <style name="NavLabel.Selected.Dark" parent="NavLabel">
        <item name="android:textColor">#8C9EFF</item>
    </style>

    <style name="NavIcon.Unselected.Dark" parent="NavIcon">
        <item name="android:tint">#24263B</item>
        <item name="android:alpha">0.6</item>
    </style>

    <style name="NavLabel.Unselected.Dark" parent="NavLabel">
        <item name="android:textColor">#24263B</item>
        <item name="android:alpha">0.6</item>
    </style>

</resources>
