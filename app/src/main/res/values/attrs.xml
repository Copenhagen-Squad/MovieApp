<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="MovieCircularProgressBar">
        <attr name="strokeWidth" format="dimension" />
    </declare-styleable>

    <declare-styleable name="SectionHeaderView">
        <attr name="text" format="string" />
        <attr name="showSeeAll" format="boolean" />
    </declare-styleable>

    <declare-styleable name="AppBar">
        <attr name="AppBarTitle" format="string" />
        <attr name="AppBarCaption" format="string" />
        <attr name="icon" format="reference" />
        <attr name="showIcon" format="boolean" />
        <attr name="showEndIcon" format="boolean" />
        <attr name="showAppIcon" format="boolean" />
    </declare-styleable>

    <declare-styleable name="StarRatingView">
        <attr name="rating" format="float" />
    </declare-styleable>

    <declare-styleable name="TextField">
        <attr name="hintText" format="string" />
        <attr name="startIcon" format="reference" />
    </declare-styleable>
</resources>